{
  "name": "bytro-app",
  "version": "0.1.0",
  "description": "Bytro - Multi-model AI Chat IDE",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE; electron-vite dev",
    "start": "unset ELECTRON_RUN_AS_NODE; electron .",
    "start:built": "pnpm run build && pnpm run start",
    "build": "electron-vite build",
    "typecheck": "tsc --build --force --pretty false",
    "lint": "pnpm run typecheck",
    "test": "vitest run",
    "dist": "pnpm run build && electron-builder --mac dmg zip --arm64 --publish never",
    "dist:all": "pnpm run build && electron-builder --mac dmg zip --arm64 --x64 --publish never",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "immer": "^10.1.1",
    "lucide-react": "^0.400.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^6.28.0",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^4.5.5"
  },
  "optionalDependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.29.2",
    "@qwen-code/qwen-code": "0.15.6",
    "@tencent-ai/codebuddy-code": "2.73.0",
    "@zed-industries/codex-acp": "0.9.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^22.0.0"
    }
  }
}
